# =============================================================================
# WaliaBet - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=WaliaBet
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_URL=http://localhost:4000
APP_VERSION=1.0.0

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/bot/webhook

# ── Payment Gateways ─────────────────────────────────────────────────────────
# Telebirr (Ethiopia Telecom)
TELEBIRR_APP_ID=your-telebirr-app-id
TELEBIRR_APP_KEY=your-telebirr-app-key
TELEBIRR_APP_SECRET=your-telebirr-app-secret
TELEBIRR_MERCHANT_CODE=your-merchant-code
TELEBIRR_SHORT_CODE=your-shortcode
TELEBIRR_BASE_URL=https://openapi.ethiotelecom.et

# Chapa (Ethiopian Payment Gateway)
CHAPA_SECRET_KEY=CHASECK-your-chapa-secret-key
CHAPA_PUBLIC_KEY=CHAPUBK-your-chapa-public-key
CHAPA_BASE_URL=https://api.chapa.co/v1
CHAPA_WEBHOOK_SECRET=your-chapa-webhook-secret

# M-Pesa (Safaricom)
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_PASSKEY=your-mpesa-passkey
MPESA_SHORTCODE=your-mpesa-shortcode
MPESA_BASE_URL=https://api.safaricom.co.ke
MPESA_CALLBACK_URL=https://your-domain.com/api/payments/mpesa/callback

# CBE (Commercial Bank of Ethiopia)
CBE_MERCHANT_ID=your-cbe-merchant-id
CBE_API_KEY=your-cbe-api-key
CBE_API_SECRET=your-cbe-api-secret
CBE_BASE_URL=https://api.cbebirr.com

# ── Currency ──────────────────────────────────────────────────────────────────
DEFAULT_CURRENCY=ETB
CURRENCY_SYMBOL=Birr
MIN_DEPOSIT=100
MAX_DEPOSIT=500000
MIN_WITHDRAWAL=200
MAX_WITHDRAWAL=100000
MIN_BET=10
MAX_BET=100000

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@waliabet.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=WaliaBet <noreply@waliabet.com>

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_APP_NAME=WaliaBet
VITE_TELEGRAM_BOT_USERNAME=WaliaBetBot

# ── Railway ───────────────────────────────────────────────────────────────────
# These are set automatically by Railway - do not set manually in production
# RAILWAY_ENVIRONMENT=production
# PORT=4000
